{
  // Configurações comuns a TODOS os ambientes.
  // REGRA DE OURO: este arquivo é versionado no Git, portanto
  // NUNCA pode conter segredos (senhas, chaves, connection strings de PROD).
  // Em produção, segredos entram por VARIÁVEIS DE AMBIENTE, que o .NET
  // lê automaticamente e que SOBRESCREVEM qualquer valor daqui.

  "Logging": {
    "LogLevel": {
      // Nível mínimo de log da nossa aplicação.
      "Default": "Information",
      // O framework é muito "falante"; Warning reduz o ruído.
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  // Parâmetros PÚBLICOS do JWT — identificam quem emite e para quem.
  // A CHAVE SECRETA não está (nem nunca estará) aqui: este arquivo é
  // versionado. Em DEV ela vive no appsettings.Development.json;
  // em PROD, na variável de ambiente Jwt__ChaveSecreta.
  "Jwt": {
    "Emissor": "SGI.Api",
    "Publico": "SGI.Web",
    "ExpiracaoMinutos": 15
  }
}
